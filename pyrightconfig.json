{
    "$schema": "https://json.schemastore.org/pyrightconfig.json",
    "pythonVersion": "3.10",
    "venvPath": ".",
    "venv": ".venv",
    "include": [
        "src",
        "tests"
    ],
    "exclude": [
        ".venv",
        ".git",
        "__pycache__",
        "docs"
    ],
    "typeCheckingMode": "basic",
    "reportMissingModuleSource": "none",
    "useLibraryCodeForTypes": true,
    "stubPath": "typings",
    "extraPaths": [
        ".",
        "src"
    ]
}