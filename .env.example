# =============================================================================
# BESSAI Edge Gateway — .env.example
# Copy to config/.env and fill in your values before starting the gateway.
# =============================================================================
# USAGE:
#   cp .env.example config/.env
#   # Edit config/.env with your actual values
#   python -m src.core.main

# -----------------------------------------------------------------------------
# REQUIRED — Site Identity
# -----------------------------------------------------------------------------
SITE_ID=SITE-CL-001           # Unique ID for this deployment

# -----------------------------------------------------------------------------
# REQUIRED — BESS Hardware Connection
# -----------------------------------------------------------------------------
INVERTER_IP=192.168.1.100     # IP or DNS of Modbus inverter
INVERTER_PORT=502              # Modbus TCP port (default 502)
DRIVER_PROFILE_PATH=registry/huawei_sun2000.json

# -----------------------------------------------------------------------------
# BESS Nameplate (NTSyCS compliance calculations)
# -----------------------------------------------------------------------------
BESSAI_P_NOM_KW=1000.0        # Nominal power kW (e.g. 1000 = 1 MW)
BESSAI_Q_MAX_KVAR=484.0       # Max reactive power kVAr

# -----------------------------------------------------------------------------
# NTSyCS Compliance (GAP-001..011) — v2.12.0
# Set BESSAI_COMPLIANCE_ENABLED=false to disable (not recommended in Chile)
# -----------------------------------------------------------------------------
BESSAI_COMPLIANCE_ENABLED=true

# -----------------------------------------------------------------------------
# CEN Telemetry — mTLS (GAP-003 — NTSyCS Cap. 6.1)
# Generate certs: bash infrastructure/certs/gen_certs.sh
# -----------------------------------------------------------------------------
CEN_ENDPOINT=https://cen.coordinador.cl/api/telemetry
CEN_TLS_CERT=infrastructure/certs/client.crt  # NOT committed — generate locally
CEN_TLS_KEY=infrastructure/certs/client.key   # NOT committed — generate locally
CEN_TLS_CA=infrastructure/certs/ca.crt        # committed — public CA cert

# -----------------------------------------------------------------------------
# SCADA IEC 60870-5-104 (GAP-004 — NTSyCS Cap. 6.2)
# -----------------------------------------------------------------------------
IEC104_HOST=0.0.0.0
IEC104_PORT=2404

# -----------------------------------------------------------------------------
# CSIRT Nacional — Ciberseguridad (Ley 21.663/2024)
# Request API key at: csirt.gob.cl/registro-operadores
# -----------------------------------------------------------------------------
CSIRT_ENDPOINT=https://csirt.gob.cl/api/report
CSIRT_API_KEY=                 # Required for production — get from CSIRT

# -----------------------------------------------------------------------------
# Servicios Complementarios — CEN Market Pricing
# Reference values from CEN 2024. Operator may override per resolution.
# -----------------------------------------------------------------------------
SC_PFR_PRICE_USD_MWH=1.5
SC_R2_PRICE_USD_MWH=2.0
SC_R3_PRICE_USD_MWH=2.5
SC_QV_PRICE_USD_MWH=0.8

# -----------------------------------------------------------------------------
# AI Dispatch Agent (BEP-0200) — optional, requires bessai-agents package
# -----------------------------------------------------------------------------
BESSAI_DRL_ENABLED=false
BESSAI_DRL_MODEL_PATH=models/dispatch_policy.onnx  # from private bessai-core
# BEP-0300: active dispatch — write DRL setpoints to the inverter (requires DRL_ENABLED=true)
# WARNING: only enable after ≥2 weeks of observe-only staging and a full safety audit.
BESSAI_DRL_WRITE=false
BESSAI_WATCHDOG_ENABLED=true

# -----------------------------------------------------------------------------
# GCP Cloud Integration — optional (disable with empty values)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_PUBSUB_TOPIC=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=bessai-edge-gateway
LOG_LEVEL=INFO
HEALTH_PORT=8000

# -----------------------------------------------------------------------------
# IEEE 2030.5 / SEP 2.0 (BEP-0100) — optional
# -----------------------------------------------------------------------------
SEP2_ENABLED=false
SEP2_PORT=8443
SEP2_MAX_W=100000
SEP2_MAX_WH=400000


# -----------------------------------------------------------------------------
# Grafana Monitoring (monitoring Docker profile)
# docker compose -f docker-compose.production.yml --profile monitoring up -d
# Generate a strong password: openssl rand -base64 24
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=          # Required — set a strong unique password

# end of .env.example
